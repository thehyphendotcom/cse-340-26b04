<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <h2>Upcoming Service Projects</h2>

        <ul>
            <% projects.forEach(project => { %>
            <% const formattedDate = new Date(project.project_date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                }); %>
                <li><strong><%= formattedDate %>: <%= project.title %> (<em><%= project.organization_name %></em>)</strong></li>
            <% }); %>
        </ul>
    </main>

<%- include('partials/footer') %>